{
    "name": "minabeter/analyze-website",
    "description": "Website analytics package for Laravel and Filament",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Mina\\AnalyzeWebsite\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Mina Girgis",
            "email": "minagiergies@gmail.com"
        }
    ],
     "keywords": [
        "laravel",
        "filament",
        "analytics",
        "dashboard",
        "plugin",
        "website analytics"
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Mina\\AnalyzeWebsite\\AnalyzeWebsiteServiceProvider"
            ]
        },
        "filament": {
            "plugins": [
                "Mina\\AnalyzeWebsite\\AnalyzeWebsitePlugin"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "filament/support": "^4.0 || ^5.0"
    },
    "config": {
        "sort-packages": true
    }
}
